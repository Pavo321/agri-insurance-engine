# ─── Database ────────────────────────────────────────────
POSTGRES_DSN=postgresql+asyncpg://agri:password@localhost:5432/agri_engine
REDIS_URL=redis://localhost:6379/0

# ─── ISRO Bhuvan ─────────────────────────────────────────
BHUVAN_API_KEY=your_bhuvan_api_key_here

# ─── IMD Weather ─────────────────────────────────────────
IMD_API_TOKEN=your_imd_token_here

# ─── NASA EARTHDATA ──────────────────────────────────────
NASA_EARTHDATA_TOKEN=your_nasa_token_here

# ─── Fasal Bima / PMFBY ──────────────────────────────────
FASAL_BIMA_API_KEY=your_pmfby_key_here

# ─── UPI Payout (Razorpay sandbox) ───────────────────────
UPI_MERCHANT_ID=your_merchant_id
UPI_API_KEY=your_upi_api_key
UPI_API_BASE_URL=https://api.razorpay.com/v1

# ─── Encryption ──────────────────────────────────────────
# Fernet key for encrypting UPI IDs and bank accounts at rest
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_ENCRYPTION_KEY=your_fernet_key_here

# ─── Processing ──────────────────────────────────────────
DASK_SCHEDULER_ADDRESS=
SPARK_MASTER_URL=spark://localhost:7077
PILOT_STATE_CODE=MH

# ─── Payout Limits ───────────────────────────────────────
MAX_PAYOUT_PER_EVENT_INR=25000.0

# ─── Thresholds (overridable without code change) ────────
NDVI_CHANGE_THRESHOLD=-0.30
FLOOD_RAINFALL_48H_MM=200.0
DROUGHT_RAINFALL_14D_MM=20.0
SOIL_VWC_THRESHOLD=15.0
